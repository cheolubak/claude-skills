{
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard*)",
      "Bash(DROP *)",
      "Bash(DELETE FROM *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_TOOL_INPUT\" in *'rm -rf /'*|*'rm -rf ~'*|*'git push --force'*|*'git push -f '*|*'git reset --hard'*|*'DROP TABLE'*|*'DROP DATABASE'*) echo 'BLOCK: 위험한 명령이 감지되었습니다. 사용자에게 확인하세요.' >&2; exit 2;; esac"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$HOME/.claude/notify.sh\" ] && bash \"$HOME/.claude/notify.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/stop-notify.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/commit-session.sh",
            "timeout": 120,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline.sh"
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "in-process"
}
