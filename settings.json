{
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard*)",
      "Bash(DROP *)",
      "Bash(DELETE FROM *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_TOOL_INPUT\" in *'rm -rf /'*|*'rm -rf ~'*|*'git push --force'*|*'git push -f '*|*'git reset --hard'*|*'DROP TABLE'*|*'DROP DATABASE'*) echo 'BLOCK: 위험한 명령이 감지되었습니다. 사용자에게 확인하세요.' >&2; exit 2;; esac"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$HOME/.claude/notify.sh\" ] && bash \"$HOME/.claude/notify.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"title\": \"Claude Code\", \"message\": \"작업이 완료되었습니다.\"}' | bash \"$HOME/.claude/notify.sh\""
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "teammateMode": "in-process",
  "skipDangerousModePermissionPrompt": true
}
